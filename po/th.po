#: src/zephyr1.c:62
#, c-format
msgid "%s: write error\n"
msgstr "%s: ข้อผิดพลาดในการเขียน\n"

#: src/zephyr1.c:69
msgid ""
"Usage: zephyr1 [OPTION]... [FILE]...\n"
"Concatenate FILE(s) to standard output. With no FILE, or when FILE is -,\n"
"read standard input.\n"
msgstr ""
"การใช้งาน: zephyr1 [OPTION]... [FILE]...\n"
"ต่อเนื้อหาของ FILE ไปยังเอาต์พุตมาตรฐาน หากไม่มี FILE หรือ FILE เป็น -,\n"
"จะอ่านจากอินพุตมาตรฐาน\n"

#: src/zephyr1.c:75
msgid "repeat for more verbose loggings\n"
msgstr "ใส่ซ้ำเพื่อแสดงบันทึกแบบละเอียดมากขึ้น\n"

#: src/zephyr1.c:77
msgid "show less logging messages\n"
msgstr "แสดงข้อความบันทึกให้น้อยลง\n"

#: src/zephyr1.c:79
msgid "display this help and exit\n"
msgstr "แสดงความช่วยเหลือนี้และออก\n"

#: src/zephyr1.c:81
msgid "output version information and exit\n"
msgstr "แสดงข้อมูลเวอร์ชันและออก\n"

#: src/zephyr1.c:83
#, c-format
msgid "Report bugs to: <%s>\n"
msgstr "รายงานบั๊กไปที่: <%s>\n"

#: src/zephyr1.c:115
#, c-format
