#: src/zephyr1.c:58
#, c-format
msgid "%s: write error\n"
msgstr "%s: 쓰기 오류\n"

#: src/zephyr1.c:65
msgid ""
"Usage: zephyr1 [OPTION]... [FILE]...\n"
"Concatenate FILE(s) to standard output. With no FILE, or when FILE is -,\n"
"read standard input.\n"
msgstr ""
"사용법: zephyr1 [OPTION]... [FILE]...\n"
"FILE 내용을 이어서 표준 출력으로 보냅니다. FILE이 없거나 FILE이 - 이면,\n"
"표준 입력을 읽습니다.\n"

#: src/zephyr1.c:71
msgid "repeat for more verbose loggings\n"
msgstr "더 자세한 로그를 보려면 반복 지정\n"

#: src/zephyr1.c:73
msgid "show less logging messages\n"
msgstr "로그 메시지를 더 적게 표시\n"

#: src/zephyr1.c:75
msgid "display this help and exit\n"
msgstr "도움말을 표시하고 종료\n"

#: src/zephyr1.c:77
msgid "output version information and exit\n"
msgstr "버전 정보를 표시하고 종료\n"

#: src/zephyr1.c:79
#, c-format
msgid "Report bugs to: <%s>\n"
msgstr "버그 제보: <%s>\n"

