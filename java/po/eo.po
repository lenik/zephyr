#: src/Main.java:26
msgid ""
"Usage: puff1 [OPTION]... [FILE]...\n"
"Concatenate FILE(s) to standard output. With no FILE, or when FILE is -,\n"
"read standard input.\n"
msgstr ""
"Uzo: puff1 [OPTION]... [FILE]...\n"
"Kunigas FILE(j)n al norma eligo. Sen FILE, au kiam FILE estas -,\n"
"legi de norma enigo.\n"

#: src/Main.java:31
msgid "repeat for more verbose loggings\n"
msgstr "ripetu por pli detalaj protokoloj\n"

#: src/Main.java:33
msgid "show less logging messages\n"
msgstr "montri malpli da protokolaj mesagxoj\n"

#: src/Main.java:35
msgid "display this help and exit\n"
msgstr "montri cxi tiun helpon kaj eliri\n"

#: src/Main.java:37
msgid "output version information and exit\n"
msgstr "montri versiajn informojn kaj eliri\n"

#: src/Main.java:39
#, java-printf-format
msgid "Report bugs to: <%s>\n"
msgstr "Raportu cimojn al: <%s>\n"

