#: src/puff1.c:32
msgid ""
"Usage: puff1 [OPTION]... [FILE]...\n"
"Concatenate FILE(s) to standard output. With no FILE, or when FILE is -,\n"
"read standard input.\n"
msgstr ""
"Uso: puff1 [OPTION]... [FILE]...\n"
"Concatena i FILE sull'output standard. Senza FILE, o quando FILE e -,\n"
"legge dallo standard input.\n"

#: src/puff1.c:38
msgid "repeat for more verbose loggings\n"
msgstr "ripeti per ottenere log piu verbosi\n"

#: src/puff1.c:40
msgid "show less logging messages\n"
msgstr "mostra meno messaggi di log\n"

#: src/puff1.c:42
msgid "display this help and exit\n"
msgstr "mostra questo aiuto ed esce\n"

#: src/puff1.c:44
msgid "output version information and exit\n"
msgstr "mostra le informazioni di versione ed esce\n"

#: src/puff1.c:46
#, c-format
