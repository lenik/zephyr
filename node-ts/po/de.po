#: src/puff1.mjs:21
msgid ""
"Usage: puff1 [OPTION]... [FILE]...\n"
"Concatenate FILE(s) to standard output. With no FILE, or when FILE is -,\n"
"read standard input.\n"
msgstr ""
"Verwendung: puff1 [OPTION]... [FILE]...\n"
"Verkettet FILE(s) zur Standardausgabe. Ohne FILE oder wenn FILE - ist,\n"
"wird von der Standardeingabe gelesen.\n"

#: src/puff1.mjs:28
msgid "repeat for more verbose loggings\n"
msgstr "wiederholen fuer ausfuehrlichere Protokollmeldungen\n"

#: src/puff1.mjs:30
msgid "show less logging messages\n"
msgstr "weniger Protokollmeldungen anzeigen\n"

#: src/puff1.mjs:32
msgid "display this help and exit\n"
msgstr "diese Hilfe anzeigen und beenden\n"

#: src/puff1.mjs:34
msgid "output version information and exit\n"
msgstr "Versionsinformationen anzeigen und beenden\n"

#: src/puff1.mjs:36
#, javascript-format
msgid "Report bugs to: <%s>\n"
msgstr "Fehler melden an: <%s>\n"

