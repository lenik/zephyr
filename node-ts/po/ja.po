#: src/puff1.mjs:21
msgid ""
"Usage: puff1 [OPTION]... [FILE]...\n"
"Concatenate FILE(s) to standard output. With no FILE, or when FILE is -,\n"
"read standard input.\n"
msgstr ""
"使い方: puff1 [OPTION]... [FILE]...\n"
"FILE を連結して標準出力へ出力します。FILE がない場合、または FILE が - の場合"
"は、\n"
"標準入力を読み取ります。\n"

#: src/puff1.mjs:28
msgid "repeat for more verbose loggings\n"
msgstr "さらに詳細なログを出すには繰り返して指定\n"

#: src/puff1.mjs:30
msgid "show less logging messages\n"
msgstr "ログメッセージを少なく表示\n"

#: src/puff1.mjs:32
msgid "display this help and exit\n"
msgstr "このヘルプを表示して終了\n"

#: src/puff1.mjs:34
msgid "output version information and exit\n"
msgstr "バージョン情報を表示して終了\n"

#: src/puff1.mjs:36
#, javascript-format
